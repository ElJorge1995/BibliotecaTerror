# ============================================================================
# Librum Tenebris — .gitignore unificado del proyecto
# ============================================================================

# ---- Secretos y entornos ----
.env

# ---- Carpetas de agentes / herramientas internas ----
.agent/
.claude/

# ---- Releases empaquetadas (snapshots, no se versionan en la rama de trabajo) ----
ReleasesEstables/

# ---- Datos binarios externos (GeoLite2 MaxMind, etc.) ----
ApiLoging/data/*.mmdb

# ---- Dependencias ----
node_modules

# ---- Builds del frontend (Vite/Vue) ----
dist
dist-ssr
*.local

# ---- Logs ----
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- IDEs y sistema operativo ----
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
